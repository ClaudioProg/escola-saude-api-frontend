# ============================================================
# 🧩 .gitignore — Escola da Saúde / Residência Santos
# Padrão institucional premium para projetos React + Node + Vite
# ============================================================

# ===========================
# ✅ Logs
# ===========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
firebase-debug.log*

# ===========================
# ✅ Dependências
# ===========================
node_modules/

# ===========================
# ✅ Ambiente
# ===========================
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local
.env.backup
.env.*.backup

# ===========================
# ✅ Build / Vite / SSR / Next
# ===========================
dist/
dist-ssr/
build/
.vite/
node_modules/.vite/
.next/
out/
.parcel-cache/
.sass-cache/

# ===========================
# ✅ IDE / Editor
# ===========================
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace
.history/

# ===========================
# ✅ Cobertura de testes
# ===========================
coverage/
.nyc_output/

# ===========================
# ✅ Caches e artefatos
# ===========================
.eslintcache
.stylelintcache
.cache/
.tmp/
temp/
tmp/
.turbo/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ===========================
# ✅ Lockfiles do projeto
# (devem ser versionados)
# ===========================
!package-lock.json
!yarn.lock
!pnpm-lock.yaml
!bun.lockb

# ===========================
# ✅ Outros sensíveis / específicos
# ===========================
*.pem
*.key
*.crt
*.csr

.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
desktop.ini

certificados/
uploads/
storage/
backups/

.vercel
.render
.neon

# ===========================
# ✅ Ferramentas de testes
# ===========================
cypress/videos/
cypress/screenshots/
playwright-report/
test-results/
.vitest/
*.tap
jest-html-reporters-attach/
jest-coverage/
jest-cache/

# ===========================
# ✅ Documentação / Relatórios
# ===========================
*.log.html
*.report.html
*.bak
*.orig
*.rej

# ===========================
# ✅ Temporários gerais
# ===========================
*.tmp
*.temp
*.swp